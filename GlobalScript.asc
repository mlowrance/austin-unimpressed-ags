// main global script file


function CheckRoomMovement(Character *theChar)
{
  
  System.Log(eLogInfo, String.Format("IsMovingRight: %d", IsMovingRight));
  
  if (IsMovingRight) 
  {
    
    System.Log(eLogInfo, String.Format("IsBossActive: %d", IsBossActive));
    
    // TRIGGER CHECK: Only walk if the boss hasn't been triggered yet
    if (!IsBossActive && theChar.x < 600) 
    {
       System.Log(eLogInfo, String.Format("Austin Should be walking: %d", IsMovingRight));
      theChar.Walk(600, theChar.y, eNoBlock, eAnywhere);
    }
    else if (!IsBossActive && theChar.x >= 600)
    {
      // TRIGGER THE BOSS
      IsBossActive = true; 
      theChar.StopMoving();
      IsMovingRight = false;
      CallRoomScript(2); // Signal the room to start the dialogue/dropping
    }
  }
  else 
  {
    if (theChar.Moving) theChar.StopMoving();
  }
}

function DropRoomObject(Object *theObj, int dropToY, int yPosition) 
{
  
  theObj.Visible = true;
  
   theObj.X = yPosition; 
  
  // Start off-screen
  theObj.Y = -100; 
  
  
   while (theObj.Y < 650) 
  {
    theObj.Y += 5; // Lower number = slower speed
    Wait(1); 
  }

  // --- THE BOUNCE ---
  // A slower fall deserves a gentler bounce
  int i = 0;
  while (i < 5) { theObj.Y -= 2; i++; Wait(1); }
  i = 0;
  while (i < 5) { theObj.Y += 2; i++; Wait(1); }
  i = 0;
  while (i < 5) { theObj.Y += 2; i++; Wait(1); }
  
  ObjectLanded = true; // Now the "Space" action is unlocked!
    
}



