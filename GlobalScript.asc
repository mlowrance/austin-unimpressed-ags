// called on every game cycle, except when the game is blocked
// Inside GlobalScript.asc

int globalTouchTimer = 0;


// called on every game cycle, even when the game is blocked
function repeatedly_execute_always()
{
}

// Called when a dialog script line "run-script" is processed
function dialog_request(int param)
{
}

// called when a key is pressed
function on_key_press(eKeyCode keycode, int mod)
{
  if (keycode == eKeySpace) 
  {
    // This tells the current room: "The action button was pressed!"
    CallRoomScript(1); 
  }  
}

function repeatedly_execute() 
{
  
  if (IsMovingRight) {
  // This will show Austin's current X in the top left corner
  System.Log(eLogInfo, String.Format("Austin X: %d", cAustin.x));
}
  
  if (mouse.IsButtonDown(eMouseLeft)) 
  {
    globalTouchTimer++;
  } 
  else 
  {
    // TWEAK: Increase the window slightly (from 10 to 15) 
    // Sometimes mobile refreshes make 10 frames (~0.2s) too short to catch
    if (globalTouchTimer > 0 && globalTouchTimer <= 15) 
    {
      on_key_press(eKeySpace,  0); 
    }
    globalTouchTimer = 0;
  }
  
  // IsMovingRight logic...
  if (IsKeyPressed(eKeyRightArrow) || (mouse.IsButtonDown(eMouseLeft) && globalTouchTimer > 15)) 
  {
    IsMovingRight = true;
  }
  else 
  {
    IsMovingRight = false;
  }
  
  // Update the movement variable based on input
  if (IsKeyPressed(eKeyRightArrow) || (mouse.IsButtonDown(eMouseLeft) && globalTouchTimer > 15)) 
  {
    IsMovingRight = true;
  }
  else 
  {
    IsMovingRight = false;
  }
  
  // Apply movement to Austin no matter what room he's in
  CheckRoomMovement(cAustin);
  
}


