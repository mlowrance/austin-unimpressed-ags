function on_event(EventType event, int data) 
{
  if (event == eEventEnterRoomBeforeFadein) 
  {
    // Check which room we just entered and update the slider
    if (data == 2) sldRetirement.Value = 0; // Room 2: Empty
    else if (data == 3) sldRetirement.Value = 1; // Room 3: 1/3
    else if (data == 4) sldRetirement.Value = 2; // Room 4: 2/3
    else if (data == 5) sldRetirement.Value = 3; // Final Room: Full!
  }
}

