// room script file

function room_Load() {
    
   // 1. Reset Global Logic
  IsBossActive = false;
  ObjectLanded = false;
  IsMovingRight = false;
  oPRRequest.Visible = false;
}

function on_call(int value)
{
  if (value == 1) // 1 is our code for "Action Button"
  {
    if (ObjectLanded) 
    {
      oUnimpressedBubble.Visible = true;
      SetTimer(1, 180);
    }
  }
    
  if (value == 2) // 2 is boss triggered
  {
     if (IsBossActive && !ObjectLanded) 
    {
      DropRoomObject(oPRRequest, 170); 
    }

    if (ObjectLanded) {
      cAustin.Say("I guess I'm going to miss walk time...");
    }


    CheckRoomMovement(cAustin); 
  }
      
}

function room_RepExec()
{
  if (IsTimerExpired(1))
  {
      //player.ChangeRoom(3); 
      cAustin.ChangeRoom(4, 120, 650);
  }
}
