function room_RepExec()
{
  // 1. CHECK FOR RIGHT ARROW
  if (IsKeyPressed(eKeyRightArrow)) 
  {
    // Walk to a point far off to the right (e.g., x=2000) 
    // eNoBlock is CRITICAL here so the game doesn't freeze while he walks
    cAustin.Walk(2000, cAustin.y, eNoBlock, eAnywhere);
  }
  
  // 2. CHECK FOR LEFT ARROW
  //else if (IsKeyPressed(eKeyLeftArrow))
  //{
   // cAustin.Walk(-1000, cAustin.y, eNoBlock, eAnywhere);
  //}
  
  // 3. STOP IF NO KEYS ARE PRESSED
  else 
  {
    if (cAustin.Moving) 
    {
      cAustin.StopMoving();
    }
  }
}