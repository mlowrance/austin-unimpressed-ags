function room_Load() {
    oChickenStrips.Visible = false;
}

bool chickenLanded = false; // Add this at the top of your script

function on_call(int value)
{
  if (value == 1) // 1 is our code for "Action Button"
  {
    if (chickenLanded) 
    {
      oUnimpressedBubble.Visible = true;
      //SetTimer(1, 80);
    }
  }
}


void DropTheChicken()
{
  // TWEAK #2: Move them more to the right (Changed from 650 to 800)
  oChickenStrips.X = 800; 
  
  // Start off-screen
  oChickenStrips.Y = -100; 
  
  // TWEAK #1: Make them visible now that the sequence is starting
  oChickenStrips.Visible = true;

  // TWEAK #3: SLOW FALL
  // We change the increment from 15 down to 5 for a smoother drop
  while (oChickenStrips.Y < 650) 
  {
    oChickenStrips.Y += 5; // Lower number = slower speed
    Wait(1); 
  }

  // --- THE BOUNCE ---
  // A slower fall deserves a gentler bounce
  int i = 0;
  while (i < 5) { oChickenStrips.Y -= 2; i++; Wait(1); }
  i = 0;
  while (i < 5) { oChickenStrips.Y += 2; i++; Wait(1); }
  i = 0;
  while (i < 5) { oChickenStrips.Y += 2; i++; Wait(1); }
  
  chickenLanded = true; // Now the "Space" action is unlocked!
}
bool bossTriggered = false;

function room_RepExec()
{
  
  if (IsMovingRight && cAustin.x < 600) 
  {
     cAustin.Walk(2000, cAustin.y, eNoBlock, eAnywhere);
  }
  else 
  {
     if (cAustin.Moving) cAustin.StopMoving();
  }
  
  
  
  
  // 1. CHECK FOR RIGHT ARROW
  //if (IsKeyPressed(eKeyRightArrow) && cAustin.x < 600) 
  //{
    // Walk to a point far off to the right (e.g., x=2000) 
    // eNoBlock is CRITICAL here so the game doesn't freeze while he walks
    //cAustin.Walk(2000, cAustin.y, eNoBlock, eAnywhere);
  //}
  
  
  // 3. STOP IF NO KEYS ARE PRESSED
  //else 
  //{
   // if (cAustin.Moving) 
   // {
   //   cAustin.StopMoving();
   // }
//  }
  
  // TRIGGER CHECK
  if (!bossTriggered && cAustin.x >= 600)
  {
    bossTriggered = true;
    cAustin.StopMoving();
    DropTheChicken();
  }
  
  // THE UNIMPRESSED TRIGGER
  // Check if Space (or Tap) is pressed AND the chicken has landed
  if (IsKeyPressed(eKeySpace) && chickenLanded)
  {
     oUnimpressedBubble.Visible = true;
     
     // Optional: Hide it after 2 seconds
   //  SetTimer(1, 240); 
  }
  
  //Hide bubble when timer 1 expires
  //if (IsTimerExpired(1))
  //{
    // player.ChangeRoom(3); 
 // }
  
}

