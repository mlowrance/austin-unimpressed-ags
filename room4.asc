// room script file

function room_Load()
{
 // 1. Reset Global Logic
  IsBossActive = false;
  ObjectLanded = false;
  IsMovingRight = false;
}


function on_call(int value)
{
  if (value == 1) // 1 is our code for "Action Button"
  {
    if (ObjectLanded) 
    {
      oUnimpressedBubble.Visible = true;
      //SetTimer(1, 180);
    }
  }
    
  if (value == 2) // 2 is boss triggered
  {
     if (IsBossActive && !ObjectLanded) 
    {
      DropRoomObject(oLotteryTicket, 170, 700); 
    }

    CheckRoomMovement(cAustin); 
  }
      
}

