// room script file


int blinkTimer = 0; // This keeps track of time

function room_Load()
{
  cAustin.Transparency = 100;
 
}

function room_RepExec()
{
  blinkTimer++;
  if (blinkTimer >= 40) 
  {
    // Now we toggle the Label's visibility instead of the Object
    lblPressSpace.Visible = !lblPressSpace.Visible;
    blinkTimer = 0;
  }
}

function on_call(int value)
{
  if (value == 1)
  {
    gTitleUI.Visible = false; // Hide the entire container
    cAustin.Transparency = 0;
    player.ChangeRoom(2);
  }
}

function room_Leave()
{
  //mouse.Visible = true; // Give the mouse back when we go to the game
  lblPressSpace.Visible = false;
  cAustin.Transparency = 0;
}