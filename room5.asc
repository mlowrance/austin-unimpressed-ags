// room script file

function room_Load()
{
  IsBossActive = false;
  ObjectLanded = false;
  IsMovingRight = false;
  oHouse.Baseline = 5000;
  oGameOver.Baseline = 10000;
}

function on_call(int value)
{
  if (value == 1) // 1 is our code for "Action Button"
  {
//    if (ObjectLanded) 
//    {
//      //oUnimpressedBubble.Visible = true;
//      //SetTimer(1, 180);
//      oAustinAwooga.Visible = true;
//      oRetirementFund.Visible = false;
//    }
  }
    
  if (value == 2) // 2 is boss triggered
  {
    oAustinAwooga.Visible = true;
    cAustin.Transparency = 100;
    
    SetTimer(1, 80);
    
    
    CheckRoomMovement(cAustin); 
  }
      
}

function room_RepExec()
{
  if (IsTimerExpired(1))
  {
      //player.ChangeRoom(3); 
      //cAustin.ChangeRoom(5, 120, 650);
      
    if (IsBossActive && !ObjectLanded) 
    {
      DropRoomObject(oHouse, 170, 700); 
    }

    if (ObjectLanded) 
    {   
      oRetirementFund.Visible = false;
      
    }
    
     SetTimer(2, 20);
      
  }
  
  if (IsTimerExpired(2))
  {
      //player.ChangeRoom(3); 
      //cAustin.ChangeRoom(5, 120, 650);
      
        oAustinAwooga.Visible = false;
      cAustin.Transparency = 0;
    
      oGameOver.Visible = true;
      
  }
  
  
}