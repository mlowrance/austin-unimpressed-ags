// Room 1 Script

int blinkTimer = 0; // This keeps track of time

function room_Load()
{
  mouse.Visible = false; // Hide the cursor for the title screen
  
  // Inside room_Load (Splash Screen)
  SetTimer(1, 2400); // 1 is the Timer ID, 2400 is 60 seconds
}

function room_RepExec()
{
  blinkTimer++;
  if (blinkTimer >= 40) 
  {
    // Now we toggle the Label's visibility instead of the Object
    lblPressSpace.Visible = !lblPressSpace.Visible;
    blinkTimer = 0;
  }
  
  // IsTimerExpired returns true only ONCE when it hits zero
  if (IsTimerExpired(1))
  {
    oUnimpressedBubble.Visible = true;
  }
  
  
}

function on_call(int value)
{
  if (value == 1)
  {
    //gTitleUI.Visible = false; // Hide the entire container
    player.ChangeRoom(6);
  }
}

function room_Leave()
{
  //mouse.Visible = true; // Give the mouse back when we go to the game
  //lblPressSpace.Visible = false;
}