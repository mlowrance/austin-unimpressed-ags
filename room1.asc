// Room 1 Script

function on_key_press(eKeyCode key) 
{
  if (key == eKeySpace) 
  {
    // Change '2' to your first gameplay room number
    player.ChangeRoom(2); 
  }
}

function room_Load()
{
  mouse.Visible = false;
  // Removed gStatusBar line because it hasn't been created yet
  
}

function room_Leave()
{
  mouse.Visible = true;
  // Removed gStatusBar line
}