// Room 1 Script

int blinkTimer = 0; // This keeps track of time

function room_Load()
{
  mouse.Visible = false; // Hide the cursor for the title screen
}

function room_RepExec()
{
  // This runs 40 times per second
  blinkTimer++;
  
  if (blinkTimer >= 30) // Change this number to make it blink faster or slower
  {
    oPressSpace.Visible = !oPressSpace.Visible; // Flip between visible and invisible
    blinkTimer = 0; // Reset the clock
  }
}

function on_key_press(eKeyCode key) 
{
  if (key == eKeySpace) 
  {
    // Make sure you have a Room 2 created before you try this!
    player.ChangeRoom(2); 
  }
}

function room_Leave()
{
  mouse.Visible = true; // Give the mouse back when we go to the game
}